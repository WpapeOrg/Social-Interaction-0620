NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=social_interaction
DB_USER=social_user
DB_PASSWORD=social_pass

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

JWT_SECRET=replace_with_your_secret
ADMIN_API_KEY=replace_with_admin_key

PUSH_WORKER_ENABLED=false
PUSH_WORKER_POLL_INTERVAL_MS=2000
PUSH_WORKER_BATCH_SIZE=20
PUSH_MAX_RETRIES=5
PUSH_BACKOFF_BASE_MS=5000
PUSH_BACKOFF_MAX_MS=300000
PUSH_MOCK_MODE=true
PUSH_MOCK_FAILURE_RATE=0
