page {
  background:
    radial-gradient(circle at 18% -10%, #1d2f5f 0%, rgba(29, 47, 95, 0) 44%),
    radial-gradient(circle at 82% 0%, #2a1d49 0%, rgba(42, 29, 73, 0) 38%),
    #050912;
  color: #ebf2ff;
  font-size: 28rpx;
  font-family: "SF Pro Rounded", "Avenir Next", "PingFang SC", "Hiragino Sans GB", sans-serif;
}

.container {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  position: relative;
}

.container::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.03) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1rpx, transparent 1rpx);
  background-size: 56rpx 56rpx;
  pointer-events: none;
}

.hero,
.card,
.panel {
  position: relative;
  z-index: 1;
}

.hero {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(120deg, rgba(32, 211, 255, 0.24), rgba(255, 122, 58, 0.2));
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.hero-title {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 0.3rpx;
}

.hero-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #d0d8ed;
}

.card {
  background: rgba(12, 19, 35, 0.9);
  border: 1rpx solid rgba(91, 228, 255, 0.26);
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.34);
}

.card-title {
  font-size: 34rpx;
  font-weight: 650;
  margin-bottom: 10rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #9eabc9;
}

.muted {
  color: #9eabc9;
}

.text-xs {
  font-size: 22rpx;
}

.stack-8 > * {
  margin-bottom: 8rpx;
}

.stack-12 > * {
  margin-bottom: 12rpx;
}

.stack-16 > * {
  margin-bottom: 16rpx;
}

.stack-20 > * {
  margin-bottom: 20rpx;
}

.stack-8 > *:last-child,
.stack-12 > *:last-child,
.stack-16 > *:last-child,
.stack-20 > *:last-child {
  margin-bottom: 0;
}

.row {
  display: flex;
  align-items: center;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gap-12 {
  gap: 12rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  color: #dce8ff;
  font-size: 22rpx;
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  background: rgba(255, 255, 255, 0.06);
}

.chip-active {
  border-color: rgba(79, 215, 255, 0.6);
  background: rgba(43, 175, 255, 0.22);
}

.btn-primary,
.btn-secondary,
.btn-danger {
  border-radius: 14rpx;
  border: 0;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(90deg, #17c4ff, #3b78ff);
  color: #f5fbff;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: #dce7ff;
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.btn-danger {
  background: linear-gradient(90deg, #ff8b48, #ff5a44);
  color: #fff8f3;
}

input,
textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 16rpx;
  color: #eef3ff;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.bubble {
  max-width: 78%;
  margin-bottom: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  position: relative;
  z-index: 1;
}

.bubble-other {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
}

.bubble-me {
  margin-left: auto;
  background: linear-gradient(90deg, rgba(21, 192, 255, 0.24), rgba(54, 120, 255, 0.28));
  border: 1rpx solid rgba(59, 212, 255, 0.45);
}

.divider {
  height: 1rpx;
  margin: 16rpx 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.16), transparent);
}

.motion-enter {
  opacity: 0;
  transform: translateY(18rpx);
  animation: fadeUp 420ms ease-out forwards;
}

.delay-1 {
  animation-delay: 80ms;
}

.delay-2 {
  animation-delay: 160ms;
}

.delay-3 {
  animation-delay: 240ms;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
