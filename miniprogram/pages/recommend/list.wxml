<view class="container">
  <view class="hero motion-enter">
    <view class="hero-title">今日推荐</view>
    <view class="hero-subtitle">优先同城 + 兴趣相近用户</view>
  </view>
  <view wx:if="{{loading}}" class="card muted motion-enter delay-1">正在加载推荐...</view>
  <block wx:for="{{list}}" wx:key="id">
    <view class="card motion-enter delay-1">
      <view class="row-between">
        <view class="user-line">{{item.nickname}} · {{item.city || '未知城市'}}</view>
        <view class="chip chip-active">在线</view>
      </view>
      <view class="muted stack-12">{{item.bio || '这个人很神秘，还没有留下签名。'}}</view>
      <view class="actions">
        <button size="mini" class="btn-secondary" data-id="{{item.id}}" bindtap="onPass">跳过</button>
        <button class="btn-primary" size="mini" data-id="{{item.id}}" bindtap="onLike">喜欢</button>
      </view>
    </view>
  </block>
  <view wx:if="{{!loading && list.length === 0}}" class="card muted motion-enter delay-2">
    今日推荐已看完，稍后再来刷新。
  </view>
</view>
