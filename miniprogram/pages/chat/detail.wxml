<view class="container">
  <view class="hero motion-enter">
    <view class="hero-title">正在聊天</view>
    <view class="hero-subtitle">会话 #{{conversationId}} · 保持友善，遇到问题可及时举报。</view>
    <view wx:if="{{connectionTip}}" class="muted text-xs">{{connectionTip}}</view>
    <view wx:if="{{typingTip}}" class="typing-tip">{{typingTip}}</view>
    <view wx:if="{{readTip}}" class="muted text-xs">{{readTip}}</view>
    <view wx:if="{{deliveryTip}}" class="delivery-tip">{{deliveryTip}}</view>
    <button size="mini" class="btn-secondary report-btn" bindtap="onReportTap">举报</button>
  </view>
  <block wx:for="{{messages}}" wx:key="id">
    <view class="{{item.sender === 'me' ? 'bubble bubble-me motion-enter delay-2' : 'bubble bubble-other motion-enter delay-1'}}">{{item.content}}</view>
  </block>
  <view class="divider"></view>
  <view class="input-row">
    <input placeholder="输入消息..." value="{{inputValue}}" bindinput="onInput" />
    <button size="mini" class="btn-primary" bindtap="onSend">发送</button>
  </view>
</view>
