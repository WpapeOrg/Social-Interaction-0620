<view class="container">
  <view class="hero motion-enter">
    <view class="hero-title">最近会话</view>
    <view class="hero-subtitle">快速回到上次聊天位置</view>
  </view>
  <view wx:if="{{loading}}" class="card muted">正在加载会话...</view>
  <block wx:for="{{conversations}}" wx:key="id">
    <view class="card motion-enter delay-1" data-id="{{item.id}}" bindtap="toDetail">
      <view class="row-between">
        <view class="session-title">{{item.title}}</view>
        <view wx:if="{{item.unreadCount > 0}}" class="chip">未读 {{item.unreadCount}}</view>
        <view wx:else class="chip">已读</view>
      </view>
      <view class="muted">{{item.lastMessage}}</view>
    </view>
  </block>
  <view wx:if="{{!loading && conversations.length === 0}}" class="card muted">
    暂无会话，先去推荐页匹配新朋友。
  </view>
</view>
